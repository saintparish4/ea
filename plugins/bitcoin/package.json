{
  "name": "@ea/plugin-bitcoin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "src/index.ts",
      "import": "src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint src/",
    "clean": "rimraf dist"
  },
  "files": [
    "src"
  ],
  "devDependencies": {
    "msw": "^2.7.0"
  },
  "dependencies": {
    "@ea/common": "workspace:^",
    "@ea/types": "workspace:^",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "ecpair": "^3.0.1",
    "tiny-secp256k1": "^2.2.4",
    "zod": "^4.3.6"
  }
}
