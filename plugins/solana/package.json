{
  "name": "@ea/plugin-solana",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "src/index.ts",
      "import": "src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint src/",
    "clean": "rimraf dist"
  },
  "files": [
    "src"
  ],
  "devDependencies": {
    "msw": "^2.7.0"
  },
  "dependencies": {
    "@ea/common": "workspace:*",
    "@ea/types": "workspace:^",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bip39": "^3.1.0",
    "ed25519-hd-key": "^1.3.0",
    "utf-8-validate": "5.0.2"
  }
}
